---
import Layout from "../layouts/Layout.astro";
import BlogRow from "../components/BlogRow.astro";
import { getRecentPosts, postDateFmt } from "../lib/content";

// PROTOTYPE (wayfinder ticket #17) — rarity-frame motif, driven by the
// post's `tier` frontmatter field, switchable via ?variant=C. Throwaway:
// fold into BlogRow.astro directly if it's kept, then drop this block.
export const prerender = false;
import BlogRowVariantC from "../components/prototype/BlogRowVariantC.astro";
const variant = Astro.url.searchParams.get("variant") === "C" ? "C" : null;

const posts = await getRecentPosts();
---

<Layout
  title="Blogs — Bhavani Chandra"
  description="Blog posts by Bhavani Chandra."
>
  <a
    href="/"
    class="fixed top-8 left-8 text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition z-50"
  >
    ← Home
  </a>
  <a
    href="/projects"
    class="fixed top-8 right-8 text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition z-50"
  >
    Projects →
  </a>
  <main class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <h1 class="text-3xl font-semibold text-white text-center mb-16">Blogs</h1>
    <div class="rows-list spotlight-group flex flex-col">
      {posts.map((post) => {
        const rowProps = {
          href: `/blogs/${post.id}`,
          title: post.data.title,
          description: post.data.description,
          date: postDateFmt.format(post.data.date),
          tags: post.data.tags,
        };
        return variant === "C" ? (
          <BlogRowVariantC {...rowProps} tier={post.data.tier} />
        ) : (
          <BlogRow {...rowProps} />
        );
      })}
    </div>
  </main>
</Layout>
