---
import Layout from "../layouts/Layout.astro";
import RailNav from "../components/RailNav.astro";
import BlogRow from "../components/BlogRow.astro";
import { getRecentPosts, postDateFmt } from "../lib/content";

const posts = await getRecentPosts();
---

<Layout
  title="Blogs — Bhavani Chandra"
  description="Blog posts by Bhavani Chandra."
>
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] md:content-start min-h-screen">
    <div class="pt-20 pb-3 pl-8 pr-20 md:pr-8">
      <a href="/" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition">← Home</a>
    </div>
    <main class="contents">
      <div class="pt-20 pl-8 pr-20 md:px-8">
        <h1 class="text-xs uppercase tracking-widest text-neutral-500">Blogs</h1>
      </div>
      <RailNav current="blogs" />
      <div class="pl-8 pr-20 md:px-8 pb-24">
        <div class="rows-list spotlight-group flex flex-col">
          {posts.map((post) => (
            <BlogRow
              href={`/blogs/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              date={postDateFmt.format(post.data.date)}
              tags={post.data.tags}
              tier={post.data.tier}
            />
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>
