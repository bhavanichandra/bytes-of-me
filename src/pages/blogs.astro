---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import MinimalIntro from "../components/MinimalIntro.astro";
import SidePanel from "../components/SidePanel.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Layout title="Blogs — Bhavani Chandra">
  <MinimalIntro />
  <SidePanel current="blogs" />

  <main class="max-w-3xl mx-auto px-6 pb-24">
    <div class="rows-list flex flex-col gap-6">
      {posts.map((post) => (
        <a href={`/blogs/${post.id}`} class="row group flex items-start justify-between gap-6 pb-6 border-b border-white/5 transition-opacity duration-300">
          <div class="flex flex-col gap-2">
            <h3 class="text-lg text-neutral-100 group-hover:text-white transition leading-snug">{post.data.title}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed max-w-md">{post.data.description}</p>
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <span class="text-xs text-neutral-500">{dateFmt.format(post.data.date)}</span>
            <span class="flex gap-1.5">
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="text-[10px] uppercase tracking-widest text-neutral-400 bg-white/5 rounded-full px-2.5 py-0.5 border border-white/10">{tag}</span>
              ))}
            </span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style is:global>
  .rows-list:hover .row:not(:hover) {
    opacity: 0.4;
  }
</style>
