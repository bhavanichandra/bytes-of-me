---
import Layout from "../layouts/Layout.astro";
import Rail from "../components/Rail.astro";
import RailNav from "../components/RailNav.astro";
import BlogRow from "../components/BlogRow.astro";
import { getRecentPosts, postDateFmt } from "../lib/content";

const posts = await getRecentPosts();
---

<Layout
  title="Blogs — Bhavani Chandra"
  description="Blog posts by Bhavani Chandra."
>
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] min-h-screen">
    <Rail />
    <main class="contents">
      <div class="pt-20 px-8">
        <h1 class="text-xs uppercase tracking-widest text-neutral-500">Blogs</h1>
      </div>
      <RailNav current="blogs" />
      <div class="px-8 pb-24">
        <div class="rows-list spotlight-group flex flex-col">
          {posts.map((post) => (
            <BlogRow
              href={`/blogs/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              date={postDateFmt.format(post.data.date)}
              tags={post.data.tags}
              tier={post.data.tier}
            />
          ))}
        </div>
      </div>
    </main>
  </div>
</Layout>
