---
// PROTOTYPE — dedicated page for the winning "journey/log" direction
// (Variant A from prototype-journey-log.astro): grid takes the page,
// log entries with blog links sit below. Still throwaway — mock data,
// not wired to the real curriculum/blog pipeline yet.
import Layout from "../layouts/Layout.astro";
import Rail from "../components/Rail.astro";
import PageIntro from "../components/PageIntro.astro";
import PixelFrame from "../components/PixelFrame.astro";
import PixelIcon from "../components/PixelIcon.astro";
import { SHIELD, BOOK, FOLDER } from "../lib/pixelIcons";
import { buildMockDays, groupByMonth, currentStreak, bestStreak, CAMPAIGNS, WEEKDAY_LABELS, type JourneyDay, type JourneyMonth } from "../lib/prototype/journeyMockData";
import { getCollection } from "astro:content";

const MONTH_ICONS = [SHIELD, BOOK, FOLDER];

function dominantCampaignColor(month: JourneyMonth): string {
  const counts: Record<string, number> = {};
  month.weeks.flat().forEach((d) => {
    if (d?.campaign) counts[d.campaign] = (counts[d.campaign] ?? 0) + 1;
  });
  const top = Object.entries(counts).sort((a, b) => b[1] - a[1])[0];
  return top ? CAMPAIGNS[top[0]].color : "rgba(255,255,255,0.35)";
}

function monthHasLogs(month: JourneyMonth): boolean {
  return month.weeks.flat().some((d) => d?.worked);
}

const days = buildMockDays(2026);

const blogPosts = await getCollection("blog");
const noted = days.filter((d) => d.note);
noted.forEach((d, i) => {
  (d as JourneyDay & { blogId?: string }).blogId = blogPosts[i % blogPosts.length]?.id;
});
const entries = days.filter((d) => d.worked).slice().reverse() as (JourneyDay & { blogId?: string })[];

const months = groupByMonth(days);
const currentMonthIndex = Math.max(0, months.findIndex((m) => m.key === "2026-07"));
const daysToDate = days.filter((d) => d.date <= "2026-07-24");
---

<Layout title="Journey — Bhavani Chandra" description="Daily log of curriculum progress.">
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] md:content-start min-h-screen">
    <Rail />
    <main class="contents">
      <div class="md:col-start-2 pt-20 pl-8 pr-20 md:px-8">
        <PageIntro />
      </div>

      <div class="md:col-start-2 pl-8 pr-8 md:pr-16 pb-24 flex flex-col gap-12 w-full">
        <section>
          <div class="flex items-center justify-between mb-4 flex-wrap gap-4">
            <div class="font-mono text-xs text-neutral-600">$ cat journey.log</div>
            <div class="flex gap-4 flex-wrap">
              <PixelFrame class="px-4 py-3 bg-[#1e1d1b]">
                <div class="text-2xl font-semibold text-white">{currentStreak(daysToDate)}</div>
                <div class="text-[10px] uppercase tracking-widest text-neutral-500">Current streak</div>
              </PixelFrame>
              <PixelFrame class="px-4 py-3 bg-[#1e1d1b]">
                <div class="text-2xl font-semibold text-white">{bestStreak(daysToDate)}</div>
                <div class="text-[10px] uppercase tracking-widest text-neutral-500">Best streak</div>
              </PixelFrame>
              <PixelFrame class="px-4 py-3 bg-[#f472b6]/10 border-pink-400/40">
                <div class="text-2xl font-semibold text-pink-400">{entries.length}</div>
                <div class="text-[10px] uppercase tracking-widest text-pink-400/70">Total days</div>
              </PixelFrame>
            </div>
          </div>

          <div class="border border-white/10 rounded-lg bg-[#161514] p-6 md:p-8 w-full">
            <div class="flex items-center gap-3 mb-6">
              <span class="relative inline-flex items-center font-mono uppercase tracking-wide text-xs px-3 py-1 bg-[#1e1d1b] border border-pink-400/50 text-pink-400">2026</span>
              <span class="text-[10px] uppercase tracking-widest text-neutral-600">Full year timeline</span>
            </div>
            <div class="grid md:grid-cols-[26rem_1fr] gap-8 items-stretch">
              <div id="month-select-list" class="grid grid-cols-2 gap-2 content-between">
                {months.map((month, mi) => {
                  const hasLogs = monthHasLogs(month);
                  return (
                    <button
                      type="button"
                      data-month-select
                      data-month-index={mi}
                      class:list={[
                        "flex items-start gap-2.5 px-3 py-2.5 border rounded-md transition text-left relative min-h-[3.5rem]",
                        mi === currentMonthIndex
                          ? "border-pink-400/70 bg-pink-400/10"
                          : "border-white/10 hover:border-white/25 hover:bg-white/[0.03]",
                        !hasLogs && "opacity-60",
                      ]}
                    >
                      <span data-month-select-marker class:list={["shrink-0 text-pink-400 font-mono text-xs leading-6", mi !== currentMonthIndex && "opacity-0"]}>▶</span>
                      <span class="shrink-0"><PixelIcon bitmap={MONTH_ICONS[mi % MONTH_ICONS.length]} color={dominantCampaignColor(month)} size={2.5} /></span>
                      <span class="flex flex-col min-w-0 gap-0.5">
                        <span class="font-mono text-[11px] uppercase tracking-wide text-neutral-300 leading-tight break-words">{month.label}</span>
                        {!hasLogs && <span class="font-mono text-[9px] uppercase tracking-wide text-neutral-600 leading-tight">No logs yet</span>}
                      </span>
                    </button>
                  );
                })}
              </div>

              <div id="month-panels" class="relative min-w-0">
                {months.map((month, mi) => (
                  <div
                    data-month-panel
                    data-month-index={mi}
                    data-month-label={month.label}
                    class:list={["w-full", mi !== currentMonthIndex && "hidden"]}
                  >
                    <div class="grid grid-cols-7 gap-2 md:gap-3 text-center w-full max-w-2xl">
                      {WEEKDAY_LABELS.map((label) => (
                        <div class="text-[10px] md:text-xs text-neutral-600 font-mono">{label}</div>
                      ))}
                      {month.weeks.flat().map((day) => {
                        if (!day) return <div class="w-full aspect-square"></div>;
                        const post = day.blogId ? blogPosts.find((p) => p.id === (day as JourneyDay & { blogId?: string }).blogId) : undefined;
                        return (
                          <button
                            type="button"
                            data-day-cell
                            data-date={day.date}
                            data-campaign={day.campaign ?? ""}
                            data-campaign-label={day.campaign ? CAMPAIGNS[day.campaign].label : ""}
                            data-campaign-color={day.campaign ? CAMPAIGNS[day.campaign].color : ""}
                            data-quest={day.quest ?? ""}
                            data-quest-type={day.questType === "side" ? "Side Quest" : "Sub Quest"}
                            data-note={day.note ?? ""}
                            data-blog-title={post?.data.title ?? ""}
                            data-blog-href={post ? `/blogs/${post.id}` : ""}
                            disabled={!day.worked}
                            class:list={[
                              "w-full aspect-square rounded-[4px] border transition relative flex items-center justify-center font-mono text-xs md:text-sm",
                              day.worked
                                ? "bg-pink-400 border-pink-300 text-black/70 hover:scale-105 hover:z-10 cursor-pointer"
                                : "bg-white/5 border-white/10 text-neutral-600 cursor-default",
                            ]}
                            aria-label={`${day.date}${day.worked ? " — worked" : ""}`}
                          >{Number(day.date.slice(-2))}</button>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <p class="text-xs text-neutral-600 mt-3 font-mono">click a month to select it, click a day to open its quest debrief</p>
        </section>
      </div>
    </main>
  </div>

  <div
    id="quest-board-backdrop"
    class="fixed inset-0 bg-black/60 z-[900] opacity-0 pointer-events-none transition-opacity duration-300"
  ></div>

  <div
    id="quest-board"
    class="fixed left-1/2 bottom-0 -translate-x-1/2 translate-y-full w-full max-w-lg z-[901] transition-transform duration-300 ease-out"
  >
    <div class="relative mx-4 mb-4 border-2 border-pink-400/50 rounded-t-lg bg-[#1a1918] p-6">
      <span class="absolute w-2.5 h-2.5 bg-pink-400/70 -top-[5px] -left-[5px]"></span>
      <span class="absolute w-2.5 h-2.5 bg-pink-400/70 -top-[5px] -right-[5px]"></span>

      <div class="flex items-center justify-between mb-4">
        <div class="font-mono text-[10px] uppercase tracking-widest text-pink-400/80">Quest Debrief</div>
        <button data-board-close class="text-neutral-500 hover:text-white text-xs font-mono">close ✕</button>
      </div>

      <div class="font-mono text-xs text-neutral-500 mb-2" data-board-date>—</div>
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <span data-board-campaign class="text-sm font-medium text-white"></span>
        <span data-board-quest-type class="text-[10px] uppercase tracking-wide font-mono px-1.5 py-0.5 border border-white/15 rounded text-neutral-400"></span>
      </div>
      <div data-board-quest class="text-sm text-neutral-400 mb-4"></div>
      <p data-board-note class="text-sm text-neutral-300 leading-relaxed mb-5"></p>
      <a
        data-board-blog-link
        href="#"
        class="hidden text-xs text-pink-400 hover:text-pink-300 transition items-center gap-1 font-mono"
      >
        Field notes →
      </a>
    </div>
  </div>
</Layout>

<script>
  function init() {
    const board = document.getElementById("quest-board");
    const backdrop = document.getElementById("quest-board-backdrop");
    if (!board || !backdrop || board.dataset.bound === "true") return;
    board.dataset.bound = "true";

    function open(cell: HTMLElement) {
      (board!.querySelector("[data-board-date]") as HTMLElement).textContent = cell.dataset.date ?? "";
      const campaignEl = board!.querySelector("[data-board-campaign]") as HTMLElement;
      campaignEl.textContent = cell.dataset.campaignLabel ?? "";
      campaignEl.style.color = cell.dataset.campaignColor || "white";
      (board!.querySelector("[data-board-quest-type]") as HTMLElement).textContent = cell.dataset.questType ?? "";
      (board!.querySelector("[data-board-quest]") as HTMLElement).textContent = cell.dataset.quest ?? "";
      (board!.querySelector("[data-board-note]") as HTMLElement).textContent =
        cell.dataset.note || `Worked on ${cell.dataset.quest}.`;

      const link = board!.querySelector("[data-board-blog-link]") as HTMLAnchorElement;
      if (cell.dataset.blogHref) {
        link.href = cell.dataset.blogHref;
        link.textContent = `Field notes: ${cell.dataset.blogTitle} →`;
        link.classList.remove("hidden");
        link.classList.add("inline-flex");
      } else {
        link.classList.add("hidden");
        link.classList.remove("inline-flex");
      }

      board!.classList.remove("translate-y-full");
      backdrop!.classList.remove("opacity-0", "pointer-events-none");
    }

    function close() {
      board!.classList.add("translate-y-full");
      backdrop!.classList.add("opacity-0", "pointer-events-none");
    }

    document.querySelectorAll<HTMLButtonElement>("[data-day-cell]:not([disabled])").forEach((cell) => {
      cell.addEventListener("click", () => open(cell));
    });
    board.querySelector("[data-board-close]")?.addEventListener("click", close);
    backdrop.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }

  function initMonthCarousel() {
    const panelsWrap = document.getElementById("month-panels");
    const listWrap = document.getElementById("month-select-list");
    if (!panelsWrap || !listWrap || (panelsWrap as HTMLElement).dataset.bound === "true") return;
    (panelsWrap as HTMLElement).dataset.bound = "true";

    const panels = Array.from(panelsWrap.querySelectorAll<HTMLElement>("[data-month-panel]"));
    const listItems = Array.from(listWrap.querySelectorAll<HTMLButtonElement>("[data-month-select]"));
    let current = panels.findIndex((p) => !p.classList.contains("hidden"));
    if (current < 0) current = panels.length - 1;

    function render() {
      panels.forEach((p, i) => {
        p.classList.toggle("hidden", i !== current);
        if (i === current) {
          p.classList.remove("month-blip");
          void p.offsetWidth; // restart the animation
          p.classList.add("month-blip");
        }
      });
      listItems.forEach((item, i) => {
        const active = i === current;
        item.classList.toggle("border-pink-400/70", active);
        item.classList.toggle("bg-pink-400/10", active);
        item.classList.toggle("scale-[1.03]", active);
        item.classList.toggle("border-white/10", !active);
        const marker = item.querySelector<HTMLElement>("[data-month-select-marker]");
        marker?.classList.toggle("opacity-0", !active);
        if (active) item.scrollIntoView({ block: "nearest", inline: "nearest", behavior: "smooth" });
      });
    }

    listItems.forEach((item, i) => {
      item.addEventListener("click", () => {
        if (current === i) return;
        current = i;
        render();
      });
    });

    document.addEventListener("keydown", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("input, textarea, [contenteditable]")) return;
      if (e.key === "ArrowUp" && current > 0) {
        current--;
        render();
      }
      if (e.key === "ArrowDown" && current < panels.length - 1) {
        current++;
        render();
      }
    });
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:page-load", initMonthCarousel);
  init();
  initMonthCarousel();
</script>

<style>
  .month-blip {
    animation: month-blip 0.35s steps(4, end);
  }
  @keyframes month-blip {
    0% { opacity: 0; transform: scale(0.92); }
    40% { opacity: 1; transform: scale(1.02); }
    100% { opacity: 1; transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .month-blip {
      animation: none;
    }
  }
</style>
