---
import Layout from "../layouts/Layout.astro";
import BlogRow from "../components/BlogRow.astro";
import CardGrid from "../components/CardGrid.astro";
import Card from "../components/Card.astro";
import { getRecentPosts, getSortedProjects, postDateFmt, projectDateFmt } from "../lib/content";

const posts = await getRecentPosts();
const projects = await getSortedProjects();
---

<Layout title="Quests — Bhavani Chandra">
  <a
    href="/"
    class="fixed top-8 left-8 text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition z-50"
  >
    ← Home
  </a>
  <main class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <h1 class="text-3xl font-semibold text-white text-center mb-16">Quests</h1>

    <div class="flex flex-col gap-16">
      <section id="blogs">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-5">Blogs</h2>
        <div class="rows-list spotlight-group flex flex-col gap-6">
          {posts.map((post) => (
            <BlogRow
              href={`/blogs/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              date={postDateFmt.format(post.data.date)}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>

      <section id="projects">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-5">Projects</h2>
        <CardGrid>
          {projects.map((project) => (
            <Card
              id={project.id}
              href={project.data.href}
              title={project.data.title}
              tag={project.data.tag}
              date={projectDateFmt.format(project.data.date)}
            />
          ))}
        </CardGrid>
      </section>
    </div>
  </main>
</Layout>
