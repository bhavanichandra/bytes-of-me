---
import Layout from "../layouts/Layout.astro";
import { getRecentPosts, getSortedProjects } from "../lib/content";

const posts = await getRecentPosts();
const projects = await getSortedProjects();
---

<Layout title="Quests — Bhavani Chandra">
  <a
    href="/"
    class="fixed top-8 left-8 text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition z-50"
  >
    ← Home
  </a>
  <main class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <h1 class="text-3xl font-semibold text-white text-center mb-16">Quests</h1>

    <div class="spotlight-group grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/quests/blogs" class="spotlight-item group rounded-2xl bg-[#242220] border border-white/10 p-8 transition-opacity duration-300">
        <h2 class="text-xl text-neutral-100 group-hover:text-white transition mb-2">Blogs</h2>
        <p class="text-sm text-neutral-500">{posts.length} post{posts.length === 1 ? "" : "s"}</p>
      </a>
      <a href="/quests/projects" class="spotlight-item group rounded-2xl bg-[#242220] border border-white/10 p-8 transition-opacity duration-300">
        <h2 class="text-xl text-neutral-100 group-hover:text-white transition mb-2">Projects</h2>
        <p class="text-sm text-neutral-500">{projects.length} project{projects.length === 1 ? "" : "s"}</p>
      </a>
    </div>
  </main>
</Layout>
