---
import Layout from "../layouts/Layout.astro";
import Rail from "../components/Rail.astro";
import RailNav from "../components/RailNav.astro";
import PageIntro from "../components/PageIntro.astro";
import BlogRow from "../components/BlogRow.astro";
import Card from "../components/Card.astro";
import { getRecentPosts, getSortedProjects, postDateFmt, projectDateFmt } from "../lib/content";

// PROTOTYPE (wayfinder ticket #18) — nav redesign variants, switchable
// via ?variant=. Throwaway: fold the winner into RailNav.astro, then
// drop this block and the /prototype nav components.
export const prerender = false;
import NavVariantA from "../components/prototype/NavVariantA.astro";
import NavVariantB from "../components/prototype/NavVariantB.astro";
import NavVariantC from "../components/prototype/NavVariantC.astro";
import PrototypeSwitcher from "../components/prototype/PrototypeSwitcher.astro";

const navVariants = ["A", "B", "C"];
const navVariantNames = {
  A: "Twin pills (evolves current pill)",
  B: "Pixel tab bar + icons",
  C: "Bracketed terminal nav",
};
const requestedNav = Astro.url.searchParams.get("variant");
const navVariant = navVariants.includes(requestedNav ?? "") ? (requestedNav as string) : null;

// Lets you preview the active-tab styling on the home page, since
// RailNav/its variants aren't mounted on /blogs or /projects yet
// (that wiring is ticket #20's job) — e.g. ?variant=B&current=blogs
const navCurrentOptions = ["home", "blogs", "projects"];
const requestedCurrent = Astro.url.searchParams.get("current");
const navCurrent = (navCurrentOptions.includes(requestedCurrent ?? "") ? requestedCurrent : "home") as
  | "home"
  | "blogs"
  | "projects";

const posts = await getRecentPosts(3);
const currentProject = (await getSortedProjects())[0];
---

<Layout
  title="Bhavani Chandra"
  description="Bhavani Chandra's personal site — blog posts and projects."
>
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] min-h-screen">
    <Rail />
    <main class="contents">
      <div class="pt-20 px-8">
        <PageIntro />
      </div>
      {navVariant === "A" && <NavVariantA current={navCurrent} />}
      {navVariant === "B" && <NavVariantB current={navCurrent} />}
      {navVariant === "C" && <NavVariantC current={navCurrent} />}
      {!navVariant && <RailNav current="home" />}
      <div class="px-8 pb-24 flex flex-col gap-16">
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-xs uppercase tracking-widest text-neutral-500">Recent posts</h2>
            <a href="/blogs" class="text-xs text-neutral-400 hover:text-white transition">View all →</a>
          </div>
          <div class="rows-list spotlight-group flex flex-col">
            {posts.map((post) => (
              <BlogRow
                href={`/blogs/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                date={postDateFmt.format(post.data.date)}
                tags={post.data.tags}
                tier={post.data.tier}
              />
            ))}
          </div>
        </section>

        {currentProject && (
          <section>
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-xs uppercase tracking-widest text-neutral-500">Current project</h2>
              <a href="/projects" class="text-xs text-neutral-400 hover:text-white transition">View all →</a>
            </div>
            <div class="max-w-sm">
              <Card
                path={`~/projects/${currentProject.id}`}
                href={`/projects/${currentProject.id}`}
                title={currentProject.data.title}
                tag={currentProject.data.tags[0]}
                date={projectDateFmt.format(currentProject.data.date)}
                tier={currentProject.data.tier}
              />
            </div>
          </section>
        )}
      </div>
    </main>
  </div>
  {navVariant && <PrototypeSwitcher current={navVariant} variants={navVariants} names={navVariantNames} />}
</Layout>
