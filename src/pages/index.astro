---
import Layout from "../layouts/Layout.astro";
import Rail from "../components/Rail.astro";
import RailNav from "../components/RailNav.astro";
import PageIntro from "../components/PageIntro.astro";
import BlogRow from "../components/BlogRow.astro";
import Card from "../components/Card.astro";
import { getRecentPosts, getSortedProjects, postDateFmt, projectDateFmt } from "../lib/content";

const posts = await getRecentPosts(3);
const currentProject = (await getSortedProjects())[0];
---

<Layout
  title="Bhavani Chandra"
  description="Bhavani Chandra's personal site — blog posts and projects."
>
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] min-h-screen">
    <Rail />
    <main class="contents">
      <div class="pt-20 px-8">
        <PageIntro />
      </div>
      <RailNav current="home" />
      <div class="px-8 pb-24 flex flex-col gap-16">
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-xs uppercase tracking-widest text-neutral-500">Recent posts</h2>
            <a href="/blogs" class="text-xs text-neutral-400 hover:text-white transition">View all →</a>
          </div>
          <div class="rows-list spotlight-group flex flex-col">
            {posts.map((post) => (
              <BlogRow
                href={`/blogs/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                date={postDateFmt.format(post.data.date)}
                tags={post.data.tags}
                tier={post.data.tier}
              />
            ))}
          </div>
        </section>

        {currentProject && (
          <section>
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-xs uppercase tracking-widest text-neutral-500">Current project</h2>
              <a href="/projects" class="text-xs text-neutral-400 hover:text-white transition">View all →</a>
            </div>
            <div class="max-w-sm">
              <Card
                path={`~/projects/${currentProject.id}`}
                href={`/projects/${currentProject.id}`}
                title={currentProject.data.title}
                tag={currentProject.data.tags[0]}
                date={projectDateFmt.format(currentProject.data.date)}
                tier={currentProject.data.tier}
              />
            </div>
          </section>
        )}
      </div>
    </main>
  </div>
</Layout>
