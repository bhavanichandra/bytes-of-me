---
import Layout from "../layouts/Layout.astro";
import RailNav from "../components/RailNav.astro";
import CardGrid from "../components/CardGrid.astro";
import Card from "../components/Card.astro";
import { getSortedProjects, projectDateFmt } from "../lib/content";

const projects = await getSortedProjects();
---

<Layout
  title="Projects — Bhavani Chandra"
  description="Projects by Bhavani Chandra."
>
  <div class="flex flex-col md:grid md:grid-cols-[16rem_1fr] md:content-start min-h-screen">
    <div class="pt-20 pb-3 pl-8 pr-20 md:pr-8">
      <a href="/" class="text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition">← Home</a>
    </div>
    <main class="contents">
      <div class="pt-20 pl-8 pr-20 md:px-8">
        <h1 class="text-xs uppercase tracking-widest text-neutral-500">Projects</h1>
      </div>
      <RailNav current="projects" />
      <div class="pl-8 pr-20 md:px-8 pb-24">
        <CardGrid>
          {projects.map((project) => (
            <Card
              path={`~/projects/${project.id}`}
              href={`/projects/${project.id}`}
              title={project.data.title}
              tag={project.data.tags[0]}
              date={projectDateFmt.format(project.data.date)}
              tier={project.data.tier}
            />
          ))}
        </CardGrid>
      </div>
    </main>
  </div>
</Layout>
