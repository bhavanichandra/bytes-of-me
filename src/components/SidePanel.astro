---
// Persistent side nav (BHA-49): separate static routes, stacked text links,
// hover = subtle border. Not a toggle between sections.
interface Props {
  current?: "blogs" | "projects";
}

const { current } = Astro.props;

const links = [
  { href: "/blogs", label: "Blogs", key: "blogs" },
  { href: "/projects", label: "Projects", key: "projects" },
];
---

<nav class="flex flex-col items-center gap-3 pb-16">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        "px-6 py-2 rounded-full border text-sm tracking-wide transition",
        current === link.key
          ? "border-white/30 text-white"
          : "border-transparent text-neutral-400 hover:border-white/20 hover:text-white",
      ]}
    >
      {link.label}
    </a>
  ))}
</nav>
