---
// TODO: placeholder copy — real bio/work/project content pending.
import "../styles/global.css";
---

<section class="w-full text-white">
  <div class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

      <div class="md:col-span-2 rounded-2xl bg-[#242220] p-8 hover:brightness-110 transition">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-3">Bio</h2>
        <p class="text-lg leading-relaxed text-neutral-100">
          Senior software engineer who likes building things end to end — from infra
          to interface. Side projects teach me things work doesn't.
        </p>
      </div>

      <div class="rounded-2xl bg-[#242220] p-8 hover:brightness-110 transition">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-3">Where I work</h2>
        <p class="text-lg text-neutral-100">
          <span class="text-red-500">Some Company</span> — platform tooling & DX.
        </p>
      </div>

      <div class="rounded-2xl bg-[#242220] p-8 hover:brightness-110 transition">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-3">This week</h2>
        <p class="text-lg text-neutral-100">
          Portfolio rebuild + prepping a dev tooling talk.
        </p>
      </div>

      <div class="rounded-2xl bg-[#242220] p-8 hover:brightness-110 transition">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-3">Current projects</h2>
        <ul class="flex flex-col gap-2 text-lg text-neutral-100">
          <li>→ bytes-of-me</li>
          <li>→ CLI tool</li>
        </ul>
      </div>

      <div class="rounded-2xl bg-[#242220] p-8 hover:brightness-110 transition">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-3">Current hackathons</h2>
        <p class="text-lg text-neutral-100">
          <span class="text-blue-400">Some Hackathon 2026</span> — real-time collab tool.
        </p>
      </div>

    </div>
  </div>
</section>
