---
// Left-column identity block. Shared across Home/Blogs/Projects;
// transition:persist keeps it mounted (no flicker) across Astro
// view-transition navigation between those routes. Sits in the grid's
// first row — see index.astro/blogs.astro/projects.astro for how the
// second row (RailNav + page content) aligns with it.
---

<aside
  class="rail w-full md:w-auto shrink-0 flex flex-col gap-3 items-start text-left pt-20 px-8 text-white"
  transition:persist
  transition:name="rail"
>
  <div id="rail-name" class="text-2xl font-semibold">Bhavani Chandra</div>
  <div id="rail-tagline" class="text-neutral-300 text-lg tracking-wide">Laziness is the mother of progress</div>
  <div id="rail-role" class="text-neutral-400 text-sm tracking-wide">Senior Software Engineer @ GE Vernova</div>
</aside>

<script>
  import { gsap } from "gsap";

  // Entrance plays once per browser tab, not on every in-app navigation —
  // replaying it on each view-transition swap read as the text flickering
  // away and back.
  const ANIMATED_KEY = "rail-animated";

  function animateRail() {
    const rail = document.querySelector(".rail");
    if (!rail) return;
    const lines = rail.querySelectorAll("#rail-name, #rail-tagline, #rail-role");

    if (sessionStorage.getItem(ANIMATED_KEY)) {
      gsap.set(lines, { opacity: 1, x: 0 });
      return;
    }

    gsap.set(lines, { opacity: 0, x: -14 });
    gsap.to(lines, { opacity: 1, x: 0, duration: 0.6, stagger: 0.12, ease: "power2.out" });
    sessionStorage.setItem(ANIMATED_KEY, "true");
  }

  if (!(window as any).__railBound) {
    (window as any).__railBound = true;
    document.addEventListener("astro:page-load", animateRail);
  }
  animateRail();
</script>
