---
import Image from "astro/components/Image.astro";
import "../styles/global.css";
---

<header class="w-full flex flex-col items-center gap-5 pt-28 pb-10 text-white">
  <Image
    src="/my-photo.svg"
    alt="profile"
    width="200"
    height="200"
    loading="eager"
    class="rounded-full"
  />

  <div class="text-2xl font-semibold text-white">
    Bhavani Chandra
  </div>

  <div class="text-neutral-300 text-lg tracking-wide">
    Laziness is the mother of progress
  </div>

  <div class="text-neutral-400 text-sm tracking-wide">
    Senior Software Engineer @ GE Vernova
  </div>

  <div class="flex items-center gap-8">
    <a
      href="https://github.com/bhavanichandra"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:opacity-80 transition"
    >
      <img src="/github.svg" alt="GitHub" class="w-6 h-6" />
    </a>
    <a
      href="mailto:bhavanichandra9+site@gmail.com"
      class="hover:opacity-80 transition"
    >
      <img src="/email.svg" alt="Email" class="w-6 h-6" />
    </a>
    <a
      href="https://www.linkedin.com/in/bhavanichandra/"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:opacity-80 transition"
    >
      <img src="/linkedin.svg" alt="LinkedIn" class="w-6 h-6" />
    </a>
  </div>
</header>
