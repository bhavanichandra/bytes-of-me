---
// Shared card for /projects. Used inside <CardGrid>.
import Tag from "./Tag.astro";

interface Props {
  id: string;
  href: string;
  title: string;
  tag: string;
  date: string;
  image?: string;
}

const { id, href, title, tag, date, image } = Astro.props;
---

<a href={href} class="card spotlight-item group flex flex-col gap-4 transition-opacity duration-300">
  <div class="relative rounded-2xl bg-[#242220] h-40 flex items-center justify-center overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <span class="text-3xl opacity-30 group-hover:opacity-50 transition">✦</span>
    )}
  </div>
  <div class="flex flex-col gap-2">
    <div class="font-mono text-[11px] text-neutral-500">~/projects/{id}</div>
    <Tag label={tag} size="md" />
    <h3 class="text-lg text-neutral-100 leading-snug group-hover:text-white transition">{title}</h3>
    <span class="text-xs text-neutral-500">{date}</span>
  </div>
</a>
