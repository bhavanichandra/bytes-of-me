---
// Shared card for blog posts and projects (BHA-50). Used inside <CardGrid>.
interface Props {
  href: string;
  title: string;
  tag: string;
  date: string;
}

const { href, title, tag, date } = Astro.props;
---

<a href={href} class="card group flex flex-col gap-4 transition-opacity duration-300">
  <div class="relative rounded-2xl bg-[#242220] h-40 flex items-center justify-center overflow-hidden">
    <span class="text-3xl opacity-30 group-hover:opacity-50 transition">✦</span>
  </div>
  <div class="flex flex-col gap-2">
    <span class="w-fit text-[10px] uppercase tracking-widest text-neutral-400 bg-white/5 rounded-full px-3 py-1 border border-white/10">
      {tag}
    </span>
    <h3 class="text-lg text-neutral-100 leading-snug group-hover:text-white transition">{title}</h3>
    <span class="text-xs text-neutral-500">{date}</span>
  </div>
</a>
