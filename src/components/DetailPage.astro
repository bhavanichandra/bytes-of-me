---
// Shared detail-page shell for any rendered content-collection entry
// (blog posts, project case studies). Builds the header (title,
// description, date, optional external link, tags) and an in-page
// section nav auto-derived from the content's own h2 headings — so a
// new entry gets the same treatment automatically, no per-page setup.
import Layout from "../layouts/Layout.astro";
import Tag from "./Tag.astro";
import PixelIcon from "./PixelIcon.astro";
import { SHIELD } from "../lib/pixelIcons";
import { TIER_COLORS } from "../lib/rarity";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
  tier?: "common" | "rare" | "epic";
  href?: string;
  backHref: string;
  backLabel: string;
  headings?: Heading[];
}

const {
  title,
  description,
  date,
  tags = [],
  tier = "common",
  href,
  backHref,
  backLabel,
  headings = [],
} = Astro.props;

const color = TIER_COLORS[tier];
const sectionHeadings = headings.filter((h) => h.depth === 2);
---

<Layout title={`${title} — Bhavani Chandra`} description={description}>
  <a
    href={backHref}
    class="fixed top-8 left-8 text-xs uppercase tracking-widest text-neutral-500 hover:text-white transition z-50"
  >
    ← {backLabel}
  </a>

  <main class="pl-6 pr-20 md:pl-8 md:pr-12 pt-20 pb-24">
    <div class="max-w-3xl mx-auto text-center mb-16">
      {color && (
        <span class="detail-pill font-mono badge-blip mb-4" style={`--tier-color: ${color};`}>
          <PixelIcon bitmap={SHIELD} color={color} size={1.5} />
          {tier}
        </span>
      )}
      <h1 class="text-3xl text-white mb-3 leading-snug">{title}</h1>
      {description && <p class="text-neutral-400 leading-relaxed">{description}</p>}
      <div class="flex items-center justify-center gap-3 mt-6">
        <span class="text-xs text-neutral-500">{date}</span>
        {href && (
          <>
            <span class="text-neutral-700">|</span>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-400 hover:text-blue-300 transition"
            >
              Visit site
            </a>
          </>
        )}
        {tags.length > 0 && (
          <span class="flex gap-1.5">
            {tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </span>
        )}
      </div>
    </div>

    <div class="flex flex-col md:flex-row md:justify-center gap-12">
      {sectionHeadings.length > 0 && (
        <nav class="md:w-48 shrink-0">
          <div class="flex flex-row md:flex-col gap-3 md:gap-2 flex-wrap md:fixed md:top-24 md:left-8 md:w-48 md:z-40">
            {sectionHeadings.map((h) => (
              <a
                href={`#${h.slug}`}
                class="text-sm text-neutral-500 hover:text-white transition"
              >
                {h.text}
              </a>
            ))}
          </div>
        </nav>
      )}
      <article class="prose-body text-neutral-200 leading-relaxed flex-1 min-w-0 max-w-4xl">
        <slot />
      </article>
    </div>
  </main>
</Layout>

<style>
  .detail-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.7rem;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tier-color);
    background: color-mix(in srgb, var(--tier-color) 12%, transparent);
    border: 1px solid var(--tier-color);
    border-radius: 999px;
  }
</style>
