---
import Image from "astro/components/Image.astro";

// Drop more photos here — the card auto-cycles through all of them
// (crossfade) once there's more than one.
const photos = ["/my-photo.svg"];
---

<div class="w-fit mx-auto">
  <div class="lanyard-rig" style="transform-origin: top center;">
    <svg class="mx-auto -mb-2 block" width="16" height="56" viewBox="0 0 16 56" fill="none">
      <line x1="8" y1="0" x2="8" y2="40" stroke="rgba(255,255,255,0.25)" stroke-width="3" />
      <rect x="0" y="38" width="16" height="14" rx="4" fill="#3a3733" stroke="rgba(255,255,255,0.2)" />
    </svg>

    <div
      data-lanyard-card
      class="w-80 rounded-2xl bg-[#242220] border border-white/10 overflow-hidden flex"
      style="box-shadow: 0 20px 40px -12px rgba(0,0,0,0.55), 0 4px 12px rgba(0,0,0,0.35);"
    >
      <div class="w-8 shrink-0 flex items-center justify-center bg-black/20 border-r border-white/10">
        <span
          class="text-[10px] tracking-widest uppercase text-neutral-500 whitespace-nowrap"
          style="writing-mode: vertical-rl; transform: rotate(180deg);"
        >
          Research &amp; Development
        </span>
      </div>

      <div class="flex-1 p-6">
        <div class="flex items-center gap-4">
          <div data-lanyard-photos class="relative w-16 h-16 shrink-0">
            {photos.map((src, i) => (
              <Image
                src={src}
                alt="profile"
                width="64"
                height="64"
                loading="eager"
                class="lanyard-photo absolute inset-0 rounded-full w-full h-full object-cover"
                style={i === 0 ? "opacity:1" : "opacity:0"}
              />
            ))}
          </div>
          <div class="flex flex-col">
            <div class="text-lg font-semibold text-white">Bhavani Chandra</div>
            <div class="text-xs text-neutral-400">Senior Software Engineer @ GE Vernova</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mt-5">
          <span class="flex items-center gap-1.5 px-3 py-1 rounded-full border border-white/15 text-xs text-neutral-300">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="8" rx="4"/><circle cx="7" cy="12" r="0.8" fill="currentColor" stroke="none"/><path d="M6 10.5v3M4.5 12h3"/><circle cx="16" cy="10.8" r="0.9" fill="currentColor" stroke="none"/><circle cx="18.2" cy="13" r="0.9" fill="currentColor" stroke="none"/></svg>
            Gamer
          </span>
          <span class="flex items-center gap-1.5 px-3 py-1 rounded-full border border-white/15 text-xs text-neutral-300">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.8 4.6L18 8l-4.2 1.4L12 14l-1.8-4.6L6 8l4.2-1.4z"/><path d="M19 14l0.9 2.3L22 17l-2.1 0.7L19 20l-0.9-2.3L16 17l2.1-0.7z"/></svg>
            AI Enthusiast
          </span>
          <span class="flex items-center gap-1.5 px-3 py-1 rounded-full border border-white/15 text-xs text-neutral-300">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s7-6.5 7-12a7 7 0 10-14 0c0 5.5 7 12 7 12z"/><circle cx="12" cy="10" r="2.5"/></svg>
            Hyderabad, India
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  function bindPhotoCycle(wrap: HTMLElement) {
    const photos = wrap.querySelectorAll<HTMLElement>(".lanyard-photo");
    if (photos.length < 2) return;

    let current = 0;
    setInterval(() => {
      const next = (current + 1) % photos.length;
      gsap.to(photos[current], { opacity: 0, duration: 0.6, ease: "power1.inOut" });
      gsap.to(photos[next], { opacity: 1, duration: 0.6, ease: "power1.inOut" });
      current = next;
    }, 4000);
  }

  function animateFallAndSwing() {
    const rig = document.querySelector(".lanyard-rig") as HTMLElement | null;
    if (!rig) return;

    gsap
      .timeline()
      .fromTo(
        rig,
        { y: -100, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.5, ease: "power3.out" }
      )
      .fromTo(
        rig,
        { rotate: -16 },
        { rotate: 0, duration: 1.4, ease: "elastic.out(1, 0.35)" },
        "-=0.35"
      );
  }

  const photoWrap = document.querySelector<HTMLElement>("[data-lanyard-photos]");
  if (photoWrap) bindPhotoCycle(photoWrap);
  animateFallAndSwing();
</script>
