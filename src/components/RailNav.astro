---
// Pixel tab bar nav: Blogs/Projects, reflecting the site's actual
// two-section structure. Sits in the grid's second row, in the same
// column as Rail's identity block, so it lines up with wherever the
// matching page content starts on the right (see page files for the
// shared grid). transition:persist keeps it mounted across navigation.
// Icon color is fixed per section (cyan for Blogs, red for Projects),
// not tied to the active tab; label text stays neutral either way.
import PixelIcon from "./PixelIcon.astro";
import { BOOK, FOLDER } from "../lib/pixelIcons";

interface Props {
  current: "home" | "blogs" | "projects";
}

const { current } = Astro.props;
---

<nav
  class="rail-nav w-full md:w-auto shrink-0 flex flex-col items-start gap-2 px-8 pb-8 text-white"
  transition:persist
  transition:name="rail-nav"
>
  <div class="nav-frame flex">
    <span class="nav-corner nav-corner--tl"></span>
    <span class="nav-corner nav-corner--tr"></span>
    <span class="nav-corner nav-corner--bl"></span>
    <span class="nav-corner nav-corner--br"></span>
    <a
      data-rail-pill
      href="/blogs"
      class:list={[
        "font-mono flex items-center gap-2 px-4 py-2 text-sm tracking-wide transition-colors",
        current === "blogs" ? "text-white" : "text-neutral-400 hover:text-white",
      ]}
    >
      <PixelIcon bitmap={BOOK} color="#22d3ee" size={1.5} />
      Blogs
    </a>
    <div class="nav-divider"></div>
    <a
      data-rail-pill
      href="/projects"
      class:list={[
        "font-mono flex items-center gap-2 px-4 py-2 text-sm tracking-wide transition-colors",
        current === "projects" ? "text-white" : "text-neutral-400 hover:text-white",
      ]}
    >
      <PixelIcon bitmap={FOLDER} color="#f87171" size={1.5} />
      Projects
    </a>
  </div>
</nav>

<style>
  .nav-frame {
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.16);
    background: #1a1918;
    clip-path: polygon(
      0 8px, 8px 8px, 8px 0,
      calc(100% - 8px) 0, calc(100% - 8px) 8px, 100% 8px,
      100% calc(100% - 8px), calc(100% - 8px) calc(100% - 8px), calc(100% - 8px) 100%,
      8px 100%, 8px calc(100% - 8px), 0 calc(100% - 8px)
    );
  }
  .nav-corner {
    position: absolute;
    width: 5px;
    height: 5px;
    background: rgba(255, 255, 255, 0.35);
  }
  .nav-corner--tl { top: -2.5px; left: 5.5px; }
  .nav-corner--tr { top: -2.5px; right: 5.5px; }
  .nav-corner--bl { bottom: -2.5px; left: 5.5px; }
  .nav-corner--br { bottom: -2.5px; right: 5.5px; }
  .nav-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.12);
    margin: 0.5rem 0;
  }
</style>

<script>
  import { gsap } from "gsap";

  const ANIMATED_KEY = "rail-nav-animated";

  function bindHover(pills: NodeListOf<Element>) {
    pills.forEach((pill) => {
      if ((pill as HTMLElement).dataset.hoverBound) return;
      (pill as HTMLElement).dataset.hoverBound = "true";
      pill.addEventListener("mouseenter", () => gsap.to(pill, { scale: 1.06, x: 4, duration: 0.25, ease: "power2.out" }));
      pill.addEventListener("mouseleave", () => gsap.to(pill, { scale: 1, x: 0, duration: 0.25, ease: "power2.out" }));
      pill.addEventListener("mousedown", () => gsap.to(pill, { scale: 0.94, duration: 0.1, ease: "power2.out" }));
      pill.addEventListener("mouseup", () => gsap.to(pill, { scale: 1.06, duration: 0.15, ease: "power2.out" }));
    });
  }

  function animateNav() {
    const nav = document.querySelector(".rail-nav");
    if (!nav) return;
    const pills = nav.querySelectorAll("[data-rail-pill]");

    if (sessionStorage.getItem(ANIMATED_KEY)) {
      gsap.set(pills, { opacity: 1, x: 0 });
      bindHover(pills);
      return;
    }

    gsap.set(pills, { opacity: 0, x: -10 });
    gsap.to(pills, { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "back.out(1.7)" });

    bindHover(pills);
    sessionStorage.setItem(ANIMATED_KEY, "true");
  }

  if (!(window as any).__railNavBound) {
    (window as any).__railNavBound = true;
    document.addEventListener("astro:page-load", animateNav);
  }
  animateNav();
</script>
