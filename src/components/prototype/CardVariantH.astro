---
// PROTOTYPE (wayfinder ticket #17) — Variant H: hybrid. Pixel-notch
// corners (A) with small corner-accent dots at the notch cuts (C, scaled
// down), a chip-shaped tag (B) in a single amber accent with a gem icon
// (A), and a faint scanline texture on the thumbnail (B). Throwaway.
import PixelIcon from "./PixelIcon.astro";
import { GEM } from "./pixelIcons";

interface Props {
  path: string;
  href: string;
  title: string;
  tag: string;
  date: string;
  image?: string;
}

const { path, href, title, tag, date, image } = Astro.props;
---

<a href={href} class="pixel-h-card group flex flex-col gap-4 transition-opacity duration-300">
  <span class="pixel-h-corner pixel-h-corner--tl"></span>
  <span class="pixel-h-corner pixel-h-corner--tr"></span>
  <span class="pixel-h-corner pixel-h-corner--bl"></span>
  <span class="pixel-h-corner pixel-h-corner--br"></span>
  <div class="relative rounded-2xl bg-[#242220] h-40 flex items-center justify-center overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <span class="text-3xl opacity-30 group-hover:opacity-50 transition">✦</span>
    )}
    <div class="pixel-h-scanlines"></div>
  </div>
  <div class="flex flex-col gap-2">
    <div class="font-mono text-[11px] text-neutral-500">{path}</div>
    <span class="pixel-h-chip font-mono">
      <PixelIcon bitmap={GEM} color="#1a1207" size={1.5} />
      {tag}
    </span>
    <h3 class="text-lg text-neutral-100 leading-snug group-hover:text-white transition">{title}</h3>
    <span class="text-xs text-neutral-500">{date}</span>
  </div>
</a>

<style>
  .pixel-h-card {
    position: relative;
    padding: 0.75rem;
    border: 1px solid rgba(227, 166, 62, 0.3);
    clip-path: polygon(
      0 12px, 12px 12px, 12px 0,
      calc(100% - 12px) 0, calc(100% - 12px) 12px, 100% 12px,
      100% calc(100% - 12px), calc(100% - 12px) calc(100% - 12px), calc(100% - 12px) 100%,
      12px 100%, 12px calc(100% - 12px), 0 calc(100% - 12px)
    );
  }
  .pixel-h-corner {
    position: absolute;
    width: 4px;
    height: 4px;
    background: #e3a63e;
  }
  .pixel-h-corner--tl { top: 6px; left: 6px; }
  .pixel-h-corner--tr { top: 6px; right: 6px; }
  .pixel-h-corner--bl { bottom: 6px; left: 6px; }
  .pixel-h-corner--br { bottom: 6px; right: 6px; }
  .pixel-h-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.2) 0px,
      rgba(0, 0, 0, 0.2) 1px,
      transparent 1px,
      transparent 3px
    );
    opacity: 0.2;
  }
  .pixel-h-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    padding: 0.2rem 0.6rem 0.2rem 0.4rem;
    font-size: 11px;
    color: #1a1207;
    background: #e3a63e;
    border-radius: 2px 8px 2px 8px;
  }
</style>
