---
// PROTOTYPE — Variant C: journal-first. Log entries are the primary
// surface; the grid is a small secondary summary widget that scrolls
// the list to a day when clicked.
import { buildMockDays, CAMPAIGNS, type JourneyDay } from "../../lib/prototype/journeyMockData";

const days = buildMockDays(182);
const entries = days.filter((d) => d.worked).slice().reverse();
const weeks: JourneyDay[][] = [];
for (let i = 0; i < days.length; i += 7) weeks.push(days.slice(i, i + 7));
---

<div class="grid md:grid-cols-[1fr_16rem] gap-8 items-start">
  <div>
    <div class="font-mono text-xs text-neutral-600 mb-4">$ tail -f journey.log</div>
    <div class="flex flex-col gap-6 max-h-[32rem] overflow-y-auto pr-2">
      {entries.map((entry) => (
        <div id={`entry-${entry.date}`} data-entry class="border-l-2 pl-4 transition" style={`border-color:${entry.campaign ? CAMPAIGNS[entry.campaign].color : "rgba(255,255,255,0.15)"}`}>
          <div class="flex items-center gap-2 mb-1">
            <span class="font-mono text-xs text-neutral-500">{entry.date}</span>
            {entry.campaign && (
              <span class="text-[10px] uppercase tracking-wide font-mono" style={`color:${CAMPAIGNS[entry.campaign].color}`}>
                {CAMPAIGNS[entry.campaign].label}
              </span>
            )}
          </div>
          <p class="text-sm text-neutral-300 leading-relaxed">
            {entry.note ?? `Worked on ${entry.quest}.`}
          </p>
        </div>
      ))}
    </div>
  </div>

  <aside class="border border-white/10 rounded-lg bg-[#1e1d1b] p-4 sticky top-6">
    <div class="text-[10px] uppercase tracking-widest text-neutral-500 mb-3">This half-year</div>
    <div class="flex flex-wrap gap-[2px] w-40">
      {days.map((day) => (
        <button
          type="button"
          data-summary-cell
          data-date={day.date}
          class="w-[7px] h-[7px] rounded-[1px]"
          style={day.worked && day.campaign ? `background:${CAMPAIGNS[day.campaign].color}` : "background:rgba(255,255,255,0.06)"}
          aria-label={day.date}
        ></button>
      ))}
    </div>
    <div class="mt-3 text-xs text-neutral-500 font-mono">{entries.length} logged days</div>
  </aside>
</div>

<script>
  function init() {
    document.querySelectorAll<HTMLButtonElement>("[data-summary-cell]").forEach((cell) => {
      if (cell.dataset.bound === "true") return;
      cell.dataset.bound = "true";
      cell.addEventListener("click", () => {
        const target = document.getElementById(`entry-${cell.dataset.date}`);
        if (!target) return;
        target.scrollIntoView({ behavior: "smooth", block: "center" });
        target.classList.add("bg-white/5");
        setTimeout(() => target.classList.remove("bg-white/5"), 900);
      });
    });
  }
  document.addEventListener("astro:page-load", init);
  init();
</script>
