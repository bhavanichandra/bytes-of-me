---
// PROTOTYPE — Variant B: grid colored by which Campaign was worked that
// day (legend below), click reveals an inline detail card under the grid.
import { buildMockDays, CAMPAIGNS, type JourneyDay } from "../../lib/prototype/journeyMockData";

const days = buildMockDays(182);
const weeks: JourneyDay[][] = [];
for (let i = 0; i < days.length; i += 7) weeks.push(days.slice(i, i + 7));
const monthLabels = weeks.map((w) => {
  const d = new Date(w[0].date);
  return d.getDate() <= 7 ? d.toLocaleDateString("en-US", { month: "short" }) : "";
});
---

<div class="font-mono text-xs text-neutral-600 mb-2">$ cat journey.log --view=by-campaign</div>

<div class="flex flex-wrap gap-4 mb-6">
  {Object.entries(CAMPAIGNS).map(([key, c]) => (
    <div class="flex items-center gap-2 text-xs text-neutral-400 font-mono">
      <span class="w-2.5 h-2.5 rounded-[2px]" style={`background:${c.color}`}></span>
      {c.label}
    </div>
  ))}
</div>

<div class="overflow-x-auto pb-2">
  <div class="flex gap-[3px]">
    {weeks.map((week, wi) => (
      <div class="flex flex-col gap-[3px]" title={monthLabels[wi]}>
        <div class="h-3 text-[9px] text-neutral-600">{monthLabels[wi]}</div>
        {week.map((day) => {
          const color = day.campaign ? CAMPAIGNS[day.campaign].color : undefined;
          return (
            <button
              type="button"
              data-day-cell
              data-date={day.date}
              data-worked={String(day.worked)}
              data-campaign={day.campaign ?? ""}
              data-quest={day.quest ?? ""}
              data-note={day.note ?? ""}
              class="w-3 h-3 rounded-[2px] border border-white/10 transition hover:scale-125 hover:z-10 relative"
              style={color ? `background:${color}` : "background:rgba(255,255,255,0.05)"}
              aria-label={day.date}
            ></button>
          );
        })}
      </div>
    ))}
  </div>
</div>

<div
  id="detail-card"
  class="mt-8 border border-white/10 rounded-lg bg-[#1e1d1b] p-5 hidden"
>
  <div class="font-mono text-xs text-neutral-600 mb-1" data-detail-date>—</div>
  <div class="flex items-center gap-2 mb-3">
    <span data-detail-swatch class="w-2.5 h-2.5 rounded-[2px]"></span>
    <span data-detail-campaign class="text-sm text-white font-medium"></span>
    <span class="text-neutral-600">/</span>
    <span data-detail-quest class="text-sm text-neutral-400"></span>
  </div>
  <p data-detail-note class="text-sm text-neutral-300 leading-relaxed"></p>
</div>

<script>
  function init() {
    const card = document.getElementById("detail-card");
    if (!card || (card as HTMLElement).dataset.bound === "true") return;
    (card as HTMLElement).dataset.bound = "true";

    document.querySelectorAll<HTMLButtonElement>("[data-day-cell]").forEach((cell) => {
      cell.addEventListener("click", () => {
        if (cell.dataset.worked !== "true") return;
        card.classList.remove("hidden");
        (card.querySelector("[data-detail-date]") as HTMLElement).textContent = cell.dataset.date ?? "";
        (card.querySelector("[data-detail-swatch]") as HTMLElement).style.background = getComputedStyle(cell).backgroundColor;
        (card.querySelector("[data-detail-campaign]") as HTMLElement).textContent = cell.dataset.campaign ?? "";
        (card.querySelector("[data-detail-quest]") as HTMLElement).textContent = cell.dataset.quest ?? "";
        (card.querySelector("[data-detail-note]") as HTMLElement).textContent = cell.dataset.note || "No note for this day.";
      });
    });
  }
  document.addEventListener("astro:page-load", init);
  init();
</script>
