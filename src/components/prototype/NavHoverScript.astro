---
// PROTOTYPE (wayfinder ticket #18) — shared GSAP hover/press binding for
// all three nav variants, same motion as the current RailNav.astro.
---

<script>
  import { gsap } from "gsap";

  function bindHover(pills: NodeListOf<Element>) {
    pills.forEach((pill) => {
      if ((pill as HTMLElement).dataset.hoverBound) return;
      (pill as HTMLElement).dataset.hoverBound = "true";
      pill.addEventListener("mouseenter", () => gsap.to(pill, { scale: 1.06, x: 4, duration: 0.25, ease: "power2.out" }));
      pill.addEventListener("mouseleave", () => gsap.to(pill, { scale: 1, x: 0, duration: 0.25, ease: "power2.out" }));
      pill.addEventListener("mousedown", () => gsap.to(pill, { scale: 0.94, duration: 0.1, ease: "power2.out" }));
      pill.addEventListener("mouseup", () => gsap.to(pill, { scale: 1.06, duration: 0.15, ease: "power2.out" }));
    });
  }

  function animateNav() {
    const nav = document.querySelector(".rail-nav");
    if (!nav) return;
    const pills = nav.querySelectorAll("[data-rail-pill]");
    gsap.set(pills, { opacity: 1, x: 0 });
    bindHover(pills);
  }

  if (!(window as any).__protoNavBound) {
    (window as any).__protoNavBound = true;
    document.addEventListener("astro:page-load", animateNav);
  }
  animateNav();
</script>
