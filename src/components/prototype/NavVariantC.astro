---
// PROTOTYPE (wayfinder ticket #18) — Variant C: bracketed terminal nav.
// No pill/button chrome at all — `[ Blogs ]` `[ Projects ]` bracket
// links with a pixel-caret prefix on the active one, leaning hardest
// into the CLI/terminal identity (see PageIntro's `$ cat bio.txt`).
import PixelIcon from "../PixelIcon.astro";
import { CARET } from "./navIcons";
import NavHoverScript from "./NavHoverScript.astro";

interface Props {
  current: "home" | "blogs" | "projects";
}

const { current } = Astro.props;
---

<nav class="rail-nav w-full md:w-auto shrink-0 flex flex-col items-start gap-1 px-8 pb-8 text-white">
  <a
    data-rail-pill
    href="/blogs"
    class:list={[
      "font-mono flex items-center gap-2 px-2 py-1 text-sm tracking-wide transition-colors",
      current === "blogs" ? "text-pink-400" : "text-neutral-400 hover:text-white",
    ]}
  >
    {current === "blogs" ? <PixelIcon bitmap={CARET} color="#f472b6" size={1.5} /> : <span class="w-[7.5px]"></span>}
    [ Blogs ]
  </a>
  <a
    data-rail-pill
    href="/projects"
    class:list={[
      "font-mono flex items-center gap-2 px-2 py-1 text-sm tracking-wide transition-colors",
      current === "projects" ? "text-pink-400" : "text-neutral-400 hover:text-white",
    ]}
  >
    {current === "projects" ? <PixelIcon bitmap={CARET} color="#f472b6" size={1.5} /> : <span class="w-[7.5px]"></span>}
    [ Projects ]
  </a>
</nav>

<NavHoverScript />
